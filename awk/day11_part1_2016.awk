
function V(p,N,f,i,g){for(f=1;f<=4;f++){g=0;for(i=1;i<=N;i++)if(p[i]==f){g=1;break}if(g)for(i=1;i<=N;i++)if(p[i+N]==f&&p[i]!=f)return 0}return 1}
function K(e,p,N,i,j,t,pr,r){for(i=1;i<=N;i++)pr[i]=p[i] p[i+N];for(i=1;i<N;i++)for(j=i+1;j<=N;j++)if(pr[i]>pr[j]){t=pr[i];pr[i]=pr[j];pr[j]=t}r=e;for(i=1;i<=N;i++)r=r"|"pr[i];return r}
BEGIN{while((getline l<"input.txt")>0){f++;n=split(l,a,/[ ,.]+/);for(i=1;i<=n;i++){if(a[i]=="generator"){m=a[i-1];if(!id[m])id[m]=++N;gs[id[m]]=f}if(a[i]=="microchip"){split(a[i-1],b,"-");m=b[1];if(!id[m])id[m]=++N;ms[id[m]]=f}}}for(i=1;i<=N;i++){pos[i]=gs[i];pos[i+N]=ms[i]}tg="4";for(i=1;i<=N;i++)tg=tg"|44";s=K(1,pos,N);if(s==tg){print 0;exit}q[0]=s;d[s]=0;v[s]=1;h=0;t=1;while(h<t){c=q[h++];split(c,pt,"|");e=pt[1];for(i=1;i<=N;i++){p[i]=substr(pt[i+1],1,1);p[i+N]=substr(pt[i+1],2,1)}k=0;for(i=1;i<=2*N;i++)if(p[i]==e)it[++k]=i;for(i=1;i<=k;i++)for(j=i;j<=k;j++)for(di=-1;di<=1;di+=2){ne=e+di;if(ne<1||ne>4)continue;p[it[i]]=ne;if(j>i)p[it[j]]=ne;if(V(p,N)){nk=K(ne,p,N);if(!(nk in v)){v[nk]=1;d[nk]=d[c]+1;if(nk==tg){print d[nk];exit}q[t++]=nk}}p[it[i]]=e;if(j>i)p[it[j]]=e}}}
