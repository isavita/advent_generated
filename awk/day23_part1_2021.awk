function abs(x){return x<0?-x:x}
function move(s,i,j,a,b,t){if(i>j){t=i;i=j;j=t}a=substr(s,i,1);b=substr(s,j,1);return substr(s,1,i-1)b substr(s,i+1,j-i-1)a substr(s,j+1)}
function path_clear(h1,h2,s,i,step){step=(h1<h2?1:-1);for(i=h1;;i+=step){if(substr(s,i,1)!=".")return 0;if(i==h2)break}return 1}
function push(v,s,i,p,t){if(s in dist&&v>=dist[s])return;dist[s]=v;h_v[++h_n]=v;h_s[h_n]=s;i=h_n;while(i>1&&h_v[i]<h_v[p=int(i/2)]){t=h_v[i];h_v[i]=h_v[p];h_v[p]=t;t=h_s[i];h_s[i]=h_s[p];h_s[p]=t;i=p}}
function pop(ts,i,c,v,s_val){ts=h_s[1];d_val=h_v[1];h_v[1]=h_v[h_n];h_s[1]=h_s[h_n--];i=1;while((c=2*i)<=h_n){if(c<h_n&&h_v[c+1]<h_v[c])c++;if(h_v[i]<=h_v[c])break;v=h_v[i];h_v[i]=h_v[c];h_v[c]=v;s_val=h_s[i];h_s[i]=h_s[c];h_s[c]=s_val;i=c}return ts}
